{
  "rewrites": [
    { "source": "/auth/google/callback", "destination": "/api/auth/google/callback" },
    { "source": "/auth/google", "destination": "/api/auth/google/index" },
    { "source": "/calendar/availability", "destination": "/api/calendar/availability" },
    { "source": "/calendar/book", "destination": "/api/calendar/book" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
